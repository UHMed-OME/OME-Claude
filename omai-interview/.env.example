# Server
PORT=3000
NODE_ENV=production

# NavTalk
NAVTALK_API_KEY=
NAVTALK_CHARACTER=navtalk.Lauren

# AI Provider (NavTalk uses this to make LLM calls from its backend)
# For Claude via NavTalk: use openai-compatible + OpenRouter baseURL
# Anthropic API is NOT OpenAI-compatible — route through OpenRouter for NavTalk
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=anthropic/claude-opus-4-5

# ElevenLabs TTS
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# QwenTTS (future - self-hosted, not implemented in MVP)
# QWEN_API_KEY=
# QWEN_VOICE_ID=

# NOTE: LM Studio requires a public tunnel (NavTalk can't reach localhost):
# AI_BASE_URL=https://<your-ngrok-id>.ngrok.io/v1
